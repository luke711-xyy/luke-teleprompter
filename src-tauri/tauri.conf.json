{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luke Teleprompter",
  "version": "0.1.0",
  "identifier": "com.luke.teleprompter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "提词器",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0b0b0c"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "中英文智能跟读提词器",
    "longDescription": "在本机离线识别中英文语音，并根据讲话内容滚动文稿的 macOS 提词器。",
    "macOS": {
      "minimumSystemVersion": "14.0",
      "signingIdentity": "-"
    }
  }
}
